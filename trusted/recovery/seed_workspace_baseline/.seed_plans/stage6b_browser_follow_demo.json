[
  {
    "kind": "bridge_status"
  },
  {
    "kind": "bridge_browser_render",
    "url": "http://allowed.test/browser/follow-source"
  },
  {
    "kind": "bridge_browser_follow_href",
    "source_url": "http://allowed.test/browser/follow-source",
    "target_url": "{last_browser_first_followable_target_url}"
  },
  {
    "kind": "write_file",
    "path": "reports/stage6b_browser_follow_report.md",
    "content_template": "task={task}\nsource_url={last_browser_follow_source_url}\nrequested_target_url={last_browser_follow_requested_target_url}\nfinal_url={last_browser_follow_final_url}\ntitle={last_browser_follow_title}\nrequest_id={last_browser_follow_request_id}\ntrace_id={last_browser_follow_trace_id}\npreview={last_browser_follow_text_preview}\n"
  },
  {
    "kind": "write_binary_base64",
    "path": "reports/stage6b_browser_follow_screenshot.png",
    "base64_template": "{last_browser_follow_screenshot_base64}"
  },
  {
    "kind": "finish",
    "summary": "stage6b browser follow demo complete"
  }
]
